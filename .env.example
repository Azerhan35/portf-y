# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paddle Billing (sandbox iken NEXT_PUBLIC_PADDLE_ENV=sandbox yapın)
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_or_test_client_side_token
NEXT_PUBLIC_PADDLE_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-signing-secret

# SEC EDGAR, tüm isteklerde açıklayıcı bir User-Agent zorunlu kılıyor
# (aksi halde 403/429 alırsınız). Format: "ŞirketAdı iletişim@eposta.com"
SEC_EDGAR_USER_AGENT="Portfey contact@yourdomain.com"

# Fiyat verisi
FINNHUB_API_KEY=your-finnhub-key

# Bildirim e-postaları
RESEND_API_KEY=your-resend-key
NOTIFICATION_FROM_EMAIL=alerts@yourdomain.com

# /api/ingest/form4 gibi cron uç noktalarını korumak için rastgele bir secret
CRON_SECRET=change-me-to-a-random-string

NEXT_PUBLIC_SITE_URL=http://localhost:3000
